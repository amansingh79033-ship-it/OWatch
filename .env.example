# ═══════════════════════════════════════════════════════════════
#  VERCEL ENVIRONMENT VARIABLES — Set ALL of these in the
#  Vercel Dashboard → Project Settings → Environment Variables
# ═══════════════════════════════════════════════════════════════

# ── AWS Credentials (required) ──────────────────────────────────
# Get these from AWS IAM Console → Users → Your User → Security Credentials
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=us-east-1

# ── SNS Topic (optional — for alerting) ─────────────────────────
# arn:aws:sns:us-east-1:123456789012:YourTopicName
AWS_SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:YourTopicName

# ── Slack Webhook (optional — for Slack alerting) ───────────────
# Create at: https://your-workspace.slack.com/apps/A0F7XDUAZ-incoming-webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# ── Gemini API Key (optional — for AI features) ────────────────
# Get at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
